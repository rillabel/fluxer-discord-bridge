/**
 * Gateway opcodes (Discord-compatible).
 * @see https://discord.com/developers/docs/topics/opcodes-and-status-codes#gateway-gateway-opcodes
 */
declare enum GatewayOpcodes {
    Dispatch = 0,
    Heartbeat = 1,
    Identify = 2,
    PresenceUpdate = 3,
    VoiceStateUpdate = 4,
    Resume = 6,
    Reconnect = 7,
    RequestGuildMembers = 8,
    InvalidSession = 9,
    Hello = 10,
    HeartbeatAck = 11
}

/**
 * Gateway dispatch event names sent by the Fluxer gateway.
 * Sourced from fluxer_gateway constants.erl. Use for type-safe event handling.
 *
 * @example
 * ```ts
 * if (payload.t === GatewayDispatchEvents.MessageCreate) {
 *   // handle message
 * }
 * ```
 */
declare const GatewayDispatchEvents: {
    /** Initial connection established; contains user, guilds, and session state. */
    readonly Ready: "READY";
    /** Connection resumed after disconnect; sequence restored. */
    readonly Resumed: "RESUMED";
    /** User's active sessions list replaced (e.g. new login). */
    readonly SessionsReplace: "SESSIONS_REPLACE";
    /** Current user's profile was updated. */
    readonly UserUpdate: "USER_UPDATE";
    /** User settings changed (theme, locale, etc.). */
    readonly UserSettingsUpdate: "USER_SETTINGS_UPDATE";
    /** Per-guild user settings changed (notifications, etc.). */
    readonly UserGuildSettingsUpdate: "USER_GUILD_SETTINGS_UPDATE";
    /** Pinned DM order changed. */
    readonly UserPinnedDmsUpdate: "USER_PINNED_DMS_UPDATE";
    /** Note on another user changed. */
    readonly UserNoteUpdate: "USER_NOTE_UPDATE";
    /** Recent mention was cleared. */
    readonly RecentMentionDelete: "RECENT_MENTION_DELETE";
    /** Message was saved (bookmarked). */
    readonly SavedMessageCreate: "SAVED_MESSAGE_CREATE";
    /** Saved message was unsaved. */
    readonly SavedMessageDelete: "SAVED_MESSAGE_DELETE";
    /** Auth session changed (login/logout on another client). */
    readonly AuthSessionChange: "AUTH_SESSION_CHANGE";
    /** User's presence (status, activity) updated. */
    readonly PresenceUpdate: "PRESENCE_UPDATE";
    /** Bot joined a guild or guild data became available. */
    readonly GuildCreate: "GUILD_CREATE";
    /** Guild was updated. */
    readonly GuildUpdate: "GUILD_UPDATE";
    /** Bot left or was removed from a guild. */
    readonly GuildDelete: "GUILD_DELETE";
    /** Member joined a guild. */
    readonly GuildMemberAdd: "GUILD_MEMBER_ADD";
    /** Member was updated (roles, nickname, etc.). */
    readonly GuildMemberUpdate: "GUILD_MEMBER_UPDATE";
    /** Member left or was removed from a guild. */
    readonly GuildMemberRemove: "GUILD_MEMBER_REMOVE";
    /** Chunk of guild members (from request_guild_members). */
    readonly GuildMembersChunk: "GUILD_MEMBERS_CHUNK";
    /** Member list view updated (lazy loading). */
    readonly GuildMemberListUpdate: "GUILD_MEMBER_LIST_UPDATE";
    /** Guild sync state (passive/lazy loading). */
    readonly GuildSync: "GUILD_SYNC";
    /** Role was created. */
    readonly GuildRoleCreate: "GUILD_ROLE_CREATE";
    /** Role was updated. */
    readonly GuildRoleUpdate: "GUILD_ROLE_UPDATE";
    /** Multiple roles updated at once. */
    readonly GuildRoleUpdateBulk: "GUILD_ROLE_UPDATE_BULK";
    /** Role was deleted. */
    readonly GuildRoleDelete: "GUILD_ROLE_DELETE";
    /** Guild emojis changed. */
    readonly GuildEmojisUpdate: "GUILD_EMOJIS_UPDATE";
    /** Guild stickers changed. */
    readonly GuildStickersUpdate: "GUILD_STICKERS_UPDATE";
    /** User was banned from a guild. */
    readonly GuildBanAdd: "GUILD_BAN_ADD";
    /** User was unbanned from a guild. */
    readonly GuildBanRemove: "GUILD_BAN_REMOVE";
    /** Channel was created. */
    readonly ChannelCreate: "CHANNEL_CREATE";
    /** Channel was updated. */
    readonly ChannelUpdate: "CHANNEL_UPDATE";
    /** Multiple channels updated at once. */
    readonly ChannelUpdateBulk: "CHANNEL_UPDATE_BULK";
    /** Channel was deleted. */
    readonly ChannelDelete: "CHANNEL_DELETE";
    /** Recipient added to group DM. */
    readonly ChannelRecipientAdd: "CHANNEL_RECIPIENT_ADD";
    /** Recipient removed from group DM. */
    readonly ChannelRecipientRemove: "CHANNEL_RECIPIENT_REMOVE";
    /** Pinned messages in a channel changed. */
    readonly ChannelPinsUpdate: "CHANNEL_PINS_UPDATE";
    /** User acknowledged viewing pinned messages. */
    readonly ChannelPinsAck: "CHANNEL_PINS_ACK";
